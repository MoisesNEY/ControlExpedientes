<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity ResultadoLaboratorio.
    -->
    <changeSet id="20260406000001-1" author="jhipster">
        <createTable tableName="resultado_laboratorio">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tipo_examen" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="resultado" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="valor_referencia" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="unidad" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="observaciones" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="fecha_examen" type="date">
                <constraints nullable="false" />
            </column>
            <column name="paciente_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <column name="consulta_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
    </changeSet>

    <changeSet id="20260406000001-2" author="jhipster">
        <addForeignKeyConstraint baseColumnNames="paciente_id"
                                 baseTableName="resultado_laboratorio"
                                 constraintName="fk_resultado_laboratorio__paciente_id"
                                 referencedColumnNames="id"
                                 referencedTableName="paciente"
                                 />

        <addForeignKeyConstraint baseColumnNames="consulta_id"
                                 baseTableName="resultado_laboratorio"
                                 constraintName="fk_resultado_laboratorio__consulta_id"
                                 referencedColumnNames="id"
                                 referencedTableName="consulta_medica"
                                 />

        <createIndex indexName="idx_resultado_laboratorio_paciente_id" tableName="resultado_laboratorio">
            <column name="paciente_id"/>
        </createIndex>

        <createIndex indexName="idx_resultado_laboratorio_fecha_examen" tableName="resultado_laboratorio">
            <column name="fecha_examen"/>
        </createIndex>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>
